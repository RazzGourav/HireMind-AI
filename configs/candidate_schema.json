{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HireMind Candidate",
  "type": "object",
  "required": ["candidate_id"],
  "properties": {
    "candidate_id": {"type": "string", "minLength": 1},
    "profile": {
      "type": "object",
      "properties": {
        "current_title": {"type": ["string", "null"]},
        "country": {"type": ["string", "null"]},
        "total_experience_months": {"type": "integer", "minimum": 0},
        "notice_period_days": {"type": ["integer", "null"], "minimum": 0},
        "open_to_work": {"type": ["boolean", "null"]}
      }
    },
    "career_history": {"type": "array"},
    "education": {"type": "array"},
    "skills": {"type": "array"},
    "signals": {"type": "object"}
  },
  "additionalProperties": true
}
